#cloud-config
# First-boot provisioning for the openorb Stage-1 guest:
#   - install Docker + socat
#   - expose dockerd on vsock:2375 (the host proxy connects here)
# No manual login needed; cloud-init runs this as root.

password: openorb
chpasswd:
  expire: false
ssh_pwauth: true

package_update: true
packages:
  - docker.io
  - socat

write_files:
  - path: /etc/systemd/system/openorb-docker-vsock.service
    permissions: "0644"
    content: |
      [Unit]
      Description=openorb: forward vsock:2375 to the Docker socket
      After=docker.service
      Requires=docker.service
      [Service]
      ExecStart=/usr/bin/socat VSOCK-LISTEN:2375,fork,reuseaddr UNIX-CONNECT:/run/docker.sock
      Restart=always
      RestartSec=1
      [Install]
      WantedBy=multi-user.target

runcmd:
  - systemctl daemon-reload
  - systemctl enable --now docker
  - systemctl enable --now openorb-docker-vsock.service
  - touch /run/openorb-ready
